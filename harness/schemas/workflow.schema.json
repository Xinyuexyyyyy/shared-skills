{
  "type": "object",
  "required": ["schema_version", "kind", "states", "initial_state", "terminal_states", "transitions", "turn_envelope", "closeout", "owned_rules"],
  "properties": {
    "schema_version": {"const": "1"},
    "kind": {"const": "workflow-config"},
    "states": {"type": "array", "minItems": 12, "items": {"type": "string"}},
    "initial_state": {"const": "input"},
    "terminal_states": {"type": "array", "items": {"type": "string"}},
    "transitions": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["from", "to"]}},
    "turn_envelope": {"type": "object", "required": ["persistence", "required"]},
    "closeout": {"type": "object", "required": ["required"]},
    "owned_rules": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["id", "owner"], "properties": {"id": {"type": "string"}, "owner": {"const": "workflow"}}, "additionalProperties": false}}
  },
  "additionalProperties": false
}
