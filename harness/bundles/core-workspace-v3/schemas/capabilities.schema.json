    "capabilities": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["id", "runtime", "enforcement", "evidence_level"], "properties": {"id": {"type": "string"}, "runtime": {"enum": ["library", "codex", "claude"]}, "enforcement": {"enum": ["hard-enforced", "contract-only", "eval-only", "unverified"]}, "evidence_level": {"type": "string"}}}},
    "owned_rules": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["id", "owner"], "properties": {"id": {"type": "string"}, "owner": {"const": "capabilities"}}, "additionalProperties": false}}
  },
  "additionalProperties": false
}
